{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nbstarry.github.io/StarryBei-ai-config/config/manifest.schema.json",
  "title": "StarryBei AI configuration manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "resources"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "description": {
      "type": "string"
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resource"
      }
    }
  },
  "$defs": {
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tool",
        "kind",
        "platforms",
        "method",
        "target",
        "description"
      ],
      "oneOf": [
        {
          "required": [
            "source"
          ]
        },
        {
          "required": [
            "sourceCandidates"
          ]
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9.-]+$"
        },
        "tool": {
          "enum": [
            "claude",
            "codex",
            "shared"
          ]
        },
        "kind": {
          "enum": [
            "config",
            "instructions",
            "marketplace",
            "prompt",
            "script",
            "skill"
          ]
        },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "windows",
              "macos",
              "linux"
            ]
          }
        },
        "method": {
          "enum": [
            "symlink",
            "junction",
            "seed"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "sourceCandidates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "target": {
          "type": "string",
          "pattern": "^\\$\\{home\\}/"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
