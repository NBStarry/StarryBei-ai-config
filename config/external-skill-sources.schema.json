{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NBStarry/StarryBei-ai-config/config/external-skill-sources.schema.json",
  "title": "External Dashboard Skill Sources",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "sources"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "repository", "branch", "path", "source"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "repository": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
          },
          "branch": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*$"
          },
          "source": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
