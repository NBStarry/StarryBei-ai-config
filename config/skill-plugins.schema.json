{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NBStarry/StarryBei-ai-config/config/skill-plugins.schema.json",
  "title": "Managed Skill Plugins",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "marketplaces", "plugins"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": 1 },
    "description": { "type": "string" },
    "marketplaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "repository", "branch", "tools"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
          "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
          "branch": { "type": "string", "minLength": 1 },
          "tools": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["claude", "codex"] }
          }
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "marketplace", "tools"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
          "marketplace": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
          "tools": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["claude", "codex"] }
          }
        }
      }
    }
  }
}
