{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git mv:*)",
      "Bash(git rebase:*)",
      "Bash(grep:*)",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(wc:*)",
      "Bash(bash:*)",
      "Bash(python3:*)",
      "Bash(ruby -e:*)",
      "Bash(tmux list-sessions:*)",
      "Bash(tmux new-session:*)",
      "Bash(tmux send-keys:*)",
      "Bash(tmux list-panes:*)",
      "Bash(tmux display-message:*)",
      "Bash(tmux capture-pane:*)",
      "WebSearch"
    ]
  },
  "outputStyle": "Explanatory",
  "teammateMode": "in-process"
}
